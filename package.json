{
  "name": "danddtemplateparsertypescript",
  "version": "1.0.0",
  "description": "D&D Template Parser — TypeScript REST API with Fastify, Zod, and Drizzle ORM",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
